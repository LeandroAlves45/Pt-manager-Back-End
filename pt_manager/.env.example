
# ========================================
# DATABASE
# ========================================
# Senha do PostgreSQL (use uma senha forte!)
DB_PASSWORD=sua_senha_forte_aqui

# ========================================
# SECURITY
# ========================================
# Gerar API key segura com: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=sua_api_key_segura_de_32_caracteres

# ========================================
# NOTIFICAÇÕES
# ========================================
TIMEZONE=Europe/Lisbon
REMINDER_HOUR_LOCAL=9
TRAINER_EMAIL=treinador@example.com

# ========================================
# EMAIL (SMTP) - Exemplo Gmail
# ========================================
# Para Gmail: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app_16_caracteres
SMTP_FROM_EMAIL=seu_email@gmail.com
SMTP_USE_TLS=true



